# Copy to .env for local development or deployment. Never commit the real .env file.

# Domain Caddy serves on. Use "localhost" for local dev — Caddy will use its internal CA
# automatically. Use a real domain in production to get automatic Let's Encrypt HTTPS.
DOMAIN=localhost

POSTGRES_DB=svechka
POSTGRES_USER=svechka
POSTGRES_PASSWORD=change-me

# Any 32+ character random string. Generate with: openssl rand -base64 48
JWT_SECRET=change-me-to-a-random-32-plus-character-string

# "dev" uses the OpenAI-compatible provider below; "prod" switches the backend to
# Yandex Cloud SpeechKit + YandexGPT (requires the YANDEX_* vars below).
SPRING_PROFILES_ACTIVE=dev

# OpenAI-compatible provider for transcription + dialogue. Point base-url/model at
# YandexGPT, GigaChat or any other RU aggregator that mirrors this API shape.
AI_BASE_URL=https://api.openai.com/v1
AI_API_KEY=
AI_TRANSCRIPTION_MODEL=whisper-1
AI_CHAT_MODEL=gpt-4o-mini

# Yandex Cloud AI Studio (SpeechKit STT + YandexGPT) — used when SPRING_PROFILES_ACTIVE=prod.
# Both services share the same service-account API key and folder.
YANDEX_FOLDER_ID=
YANDEX_API_KEY=
